<configuration>
  <property name="LOG_FILE" value="${LOG_FILE:-application.log}"/>

  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_FILE}</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
    </rollingPolicy>

    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <customFields>{"component":"possable"}</customFields>
      <includeMdc>true</includeMdc>
    </encoder>
  </appender>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
      <providers>
        <timestamp />
        <version />
        <loggerName />
        <threadName />
        <level />
        <message />
        <mdc>
          <includeMdcKey>request_id</includeMdcKey>
          <includeMdcKey>correlation_id</includeMdcKey>
          <includeMdcKey>user_id</includeMdcKey>
        </mdc>
        <globalCustomFields>{"component":"possable"}</globalCustomFields>
      </providers>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="FILE" />
    <appender-ref ref="CONSOLE" />
  </root>
</configuration> 