      "targets": [ { "expr": "increase(possable_sse_dropped_emitters{component=\"print-job-service\"}[5m])", "legendFormat": "dropped (5m)", "refId": "A" } ],
      "title": "SSE: Dropped Emitters (5m)",
      "type": "timeseries",
