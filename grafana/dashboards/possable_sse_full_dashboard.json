    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [ { "expr": "sum by (topic) (increase(possable_sse_sent{component=\"print-job-service\"}[5m]))", "legendFormat": "{{topic}}", "refId": "A" } ],
      "title": "SSE: Sent per Topic (5m)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
