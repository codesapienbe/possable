      "targets": [ { "expr": "increase(possable_sse_collapsed{component=\"print-job-service\"}[5m])", "legendFormat": "collapsed (5m)", "refId": "A" } ],
      "title": "SSE: Collapsed Events (5m)",
      "type": "timeseries",
      "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 } ] },
      "alert": {
        "name": "High Collapsed Events",
        "conditions": [
          { "evaluator": { "type": "gt", "params": [ 10 ] }, "operator": { "type": "and" }, "query": { "params": [ "A" ] }, "reducer": { "type": "sum", "params": [] } }
        ],
        "for": "5m",
        "noDataState": "OK",
        "execErrState": "ERROR"
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
